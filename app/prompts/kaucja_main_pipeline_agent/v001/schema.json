      "type": "object"
    },
    "LegalRegisterItem": {
      "additionalProperties": false,
      "properties": {
        "ref_id": {
          "pattern": "^L\\d{2}$",
          "title": "Ref Id",
          "type": "string"
        },
        "doc_id": {
          "title": "Doc Id",
          "type": "string"
        },
        "anchor_id": {
          "title": "Anchor Id",
          "type": "string"
        },
        "locator_label": {
          "title": "Locator Label",
          "type": "string"
        },
        "preview": {
          "title": "Preview",
          "type": "string"
        }
      },
      "required": [
        "ref_id",
        "doc_id",
        "anchor_id",
        "locator_label",
        "preview"
      ],
      "title": "LegalRegisterItem",
      "type": "object"
    },
    "MemoPoint": {
      "additionalProperties": false,
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "legal_ref_ids": {
          "items": {
            "type": "string"
          },
          "title": "Legal Ref Ids",
          "type": "array"
        },
        "evidence_ref_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ref Ids",
          "type": "array"
        }
      },
      "required": [
        "text"
      ],
      "title": "MemoPoint",
      "type": "object"
    },
    "RiskPoint": {
      "additionalProperties": false,
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "legal_ref_ids": {
          "items": {
            "type": "string"
          },
          "title": "Legal Ref Ids",
          "type": "array"
        }
      },
      "required": [
        "text"
      ],
      "title": "RiskPoint",
      "type": "object"
    }
