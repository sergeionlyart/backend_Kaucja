    "CitationRegister": {
      "additionalProperties": false,
      "properties": {
        "legal": {
          "items": {
            "$ref": "#/$defs/LegalRegisterItem"
          },
          "title": "Legal",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceRegisterItem"
          },
          "title": "Evidence",
          "type": "array"
        }
      },
      "title": "CitationRegister",
      "type": "object"
    },
    "EvidenceRegisterItem": {
      "additionalProperties": false,
      "properties": {
        "ref_id": {
          "pattern": "^U\\d{2}$",
          "title": "Ref Id",
          "type": "string"
        },
        "doc_id": {
          "title": "Doc Id",
          "type": "string"
        },
        "anchor_id": {
          "title": "Anchor Id",
          "type": "string"
        },
        "preview": {
          "title": "Preview",
          "type": "string"
        }
      },
      "required": [
        "ref_id",
        "doc_id",
        "anchor_id",
        "preview"
      ],
      "title": "EvidenceRegisterItem",
      "type": "object"
    },
    "FactsPoint": {
      "additionalProperties": false,
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "evidence_ref_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ref Ids",
          "type": "array"
        }
      },
      "required": [
        "text"
      ],
      "title": "FactsPoint",
      "type": "object"
    },
    "LegalAnalysisSection": {
      "additionalProperties": false,
      "properties": {
        "issue_code": {
          "title": "Issue Code",
          "type": "string"
