        "issue_title": {
          "title": "Issue Title",
          "type": "string"
        },
        "analysis_points": {
          "items": {
            "$ref": "#/$defs/MemoPoint"
          },
          "title": "Analysis Points",
          "type": "array"
        },
        "risks": {
          "items": {
            "$ref": "#/$defs/RiskPoint"
