  "additionalProperties": false,
  "properties": {
    "title": {
      "title": "Title",
      "type": "string"
    },
    "executive_summary": {
      "items": {
        "$ref": "#/$defs/MemoPoint"
      },
      "title": "Executive Summary",
      "type": "array"
    },
    "facts_considered": {
