        "$ref": "#/$defs/LegalAnalysisSection"
      },
      "title": "Legal Analysis",
      "type": "array"
    },
    "recommended_next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Recommended Next Steps",
      "type": "array"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "citation_register": {
      "$ref": "#/$defs/CitationRegister"
    }
  },
  "required": [
    "title",
    "citation_register"
  ],
  "title": "StrategicMemo",
  "type": "object"
}
