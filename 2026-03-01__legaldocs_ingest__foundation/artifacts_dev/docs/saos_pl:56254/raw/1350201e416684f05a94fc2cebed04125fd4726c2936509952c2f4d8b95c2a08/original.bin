{"links":[{"rel":"self","href":"https://www.saos.org.pl/api/judgments/56254"}],"data":{"id":56254,"courtType":"COMMON","href":"https://www.saos.org.pl/api/judgments/56254","courtCases":[{"caseNumber":"III Ca 1633/13"}],"judgmentType":"SENTENCE","judgmentDate":"2014-05-16","judges":[{"name":"Barbara Pięcek","function":null,"specialRoles":["PRESIDING_JUDGE"]},{"name":"Dorota Kozarzewska","function":null,"specialRoles":[]},{"name":"Radosław Olewczyński","function":null,"specialRoles":[]}],"source":{"code":"COMMON_COURT","judgmentUrl":"http://orzeczenia.ms.gov.pl/ncourt-api/judgement/details?id=152510000001503_III_Ca_001633_2013_Uz_2014-05-16_001","judgmentId":"152510000001503_III_Ca_001633_2013_Uz_2014-05-16_001","publisher":"Sabina Szwed","reviser":"Sabina Szwed","publicationDate":"2014-08-20"},"courtReporters":["Anna Paradowska"],"decision":null,"summary":null,"textContent":"<p>\n<strong>\n<!-- -->Sygn. akt III Ca 1633/13</strong>\n</p>\n    <div>\n      <h2>WYROK</h2>\n      <h5>W IMIENIU RZECZYPOSPOLITEJ POLSKIEJ</h5>\n      <p> Dnia 16 maja 2014 r.</p>\n      \n      <p>\n<strong>\n<!-- -->Sąd Okręgowy w Łodzi III Wydział Cywilny Odwoławczy</strong>\n</p>\n      <p>w składzie następującym:</p>\n      \n      <p>Przewodniczący:<strong>\n<!-- --> SSO Barbara Pięcek</strong>\n</p>\n      <p>Sędziowie :<strong>\n<!-- --> SO Radosław Olewczyński (ref.)</strong>\n</p>\n      <p>\n<strong>\n<!-- -->SO Dorota Kozarzewska</strong>\n</p>\n      <p>Protokolant:<strong>\n<!-- --> Anna Paradowska</strong>\n</p>\n      \n      <p>po rozpoznaniu w dniu 8 maja 2014 r. w Łodzi</p>\n      <p>na rozprawie</p>\n      <p>sprawy z powództwa<strong>\n<!-- --> <span class=\"anon-block\">W. T.</span>\n</strong>\n</p>\n      <p>przeciwko<strong>\n<!-- --> Miastu <span class=\"anon-block\">Ł.</span>\n</strong>\n</p>\n      <p>o zapłatę</p>\n      <p>na skutek apelacji powódki</p>\n      <p>od wyroku Sądu Rejonowego dla Łodzi – Śródmieścia w Łodzi</p>\n      <p>z dnia 2 sierpnia 2013 r. wydanego w sprawie II C 1302/12</p>\n      \n      <p>oddala apelację.</p>\n    </div>","legalBases":["art. 36 ust 2 ust. o najmie lokali"],"referencedRegulations":[],"keywords":["kaucja mieszkaniowa"],"referencedCourtCases":[{"caseNumber":"II C 1302/12","judgmentIds":[],"generated":true}],"receiptDate":"","meansOfAppeal":null,"judgmentResult":null,"lowerCourtJudgments":[],"division":{"id":1018,"name":"III Wydział Cywilny Odwoławczy","href":"https://www.saos.org.pl/api/ccDivisions/1018","code":"0001503","type":"Cywilny","court":{"href":"https://www.saos.org.pl/api/commonCourts/159","id":159,"name":"Sąd Okręgowy w Łodzi","code":"15251000","type":"REGIONAL"}}}}