{"links":[{"rel":"self","href":"https://www.saos.org.pl/api/judgments/175246"}],"data":{"id":175246,"courtType":"COMMON","href":"https://www.saos.org.pl/api/judgments/175246","courtCases":[{"caseNumber":"II C 636/14"}],"judgmentType":"SENTENCE","judgmentDate":"2015-06-25","judges":[{"name":"E.steckiewicz Ochocka","function":null,"specialRoles":["PRESIDING_JUDGE"]}],"source":{"code":"COMMON_COURT","judgmentUrl":"http://orzeczenia.ms.gov.pl/ncourt-api/judgement/details?id=152510000001003_II_C_000636_2014_Uz_2015-06-25_001","judgmentId":"152510000001003_II_C_000636_2014_Uz_2015-06-25_001","publisher":"Sylwia Nowakowska","reviser":"Sylwia Nowakowska","publicationDate":"2015-09-07"},"courtReporters":["K.Loska"],"decision":null,"summary":null,"textContent":"<p>Sygn.aktIIC 636/14</p>\n    <div>\n      <h2>WYROK</h2>\n      <h5>W IMIENIU RZECZYPOSPOLITEJ POLSKIEJ</h5>\n      <p>Dnia 25 czerwca 2015 r.</p>\n      <p>Sąd Okręgowy w Łodzi, w II Wydziale Cywilnym,</p>\n      <p>w składzie: Przewodniczący: SSO E. Steckiewicz-Ochocka</p>\n      <p>Protokolant: sekr. sąd. K.Loska</p>\n      <p>po rozpoznaniu w dniu 16 czerwca 2015 r. w Łodzi</p>\n      <p>na rozprawie</p>\n      <p>sprawy z powództwa <span class=\"anon-block\">H.</span> <span class=\"anon-block\">L.</span>, <span class=\"anon-block\">R.</span> <span class=\"anon-block\">R. L.</span>, <span class=\"anon-block\">A.</span> <span class=\"anon-block\">L.</span>, <span class=\"anon-block\">D. L.</span>\n</p>\n      <p>przeciwko <span class=\"anon-block\">M. C.</span>\n</p>\n      <p>o zapłatę</p>\n      <p>zasądza od <span class=\"anon-block\">M. C.</span> solidarnie na rzecz <span class=\"anon-block\">H.</span> <span class=\"anon-block\">L.</span>, <span class=\"anon-block\">R.</span> <span class=\"anon-block\">R. L.</span>, <span class=\"anon-block\">A.</span> <span class=\"anon-block\">L.</span> i <span class=\"anon-block\">D. L.</span> kwotę 162.903 zł. (sto sześćdziesiąt dwa tysiące dziewięćset trzy złote) wraz z ustawowymi odsetkami od dnia 16 listopada 2012 roku oraz kwotę 17.688 zł. (siedemnaście tysięcy sześćset osiemdziesiąt osiem złotych) tytułem zwrotu kosztów procesu.</p>\n    </div>","legalBases":["174 kro"],"referencedRegulations":[],"keywords":["kaucja mieszkaniowa"],"referencedCourtCases":[{"caseNumber":"IIC 636/14","judgmentIds":[],"generated":true}],"receiptDate":"","meansOfAppeal":null,"judgmentResult":null,"lowerCourtJudgments":[],"division":{"id":1017,"name":"II Wydział Cywilny","href":"https://www.saos.org.pl/api/ccDivisions/1017","code":"0001003","type":"Cywilny","court":{"href":"https://www.saos.org.pl/api/commonCourts/159","id":159,"name":"Sąd Okręgowy w Łodzi","code":"15251000","type":"REGIONAL"}}}}